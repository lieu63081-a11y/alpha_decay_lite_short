# --- broker selection ---
BROKER=angel                # angel | upstox
UNIVERSE=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK

# --- storage ---
DATA_DIR=./data
KEEP_DAYS=90                # auto-delete DB files older than this
FLUSH_INTERVAL_S=5          # writer batches for up to 5s
FLUSH_BATCH_MAX=1000        # OR up to 1000 ticks per flush

# --- API ---
API_HOST=0.0.0.0
API_PORT=8080

# --- Broker A: Angel One ---
ANGEL_API_KEY=
ANGEL_CLIENT_CODE=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=
ANGEL_BIDASK_SWAPPED=0      # set to 1 only after diag_bidask.py confirms

# --- Broker B: Upstox ---
UPSTOX_ACCESS_TOKEN=
# UPSTOX_INSTRUMENT_RELIANCE=NSE_EQ|INE002A01018    # per-symbol instrument codes
